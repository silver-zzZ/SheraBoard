<Window x:Class="SheraBoard.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="460" Width="640" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource PageBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Border Width="34" Height="34" Background="{StaticResource AccentSoftBrush}" CornerRadius="8" DockPanel.Dock="Left" Margin="0,0,10,0">
                <Image Source="Assets/AppIcon.png" Width="24" Height="24"/>
            </Border>
            <Button x:Name="SearchHelpButton"
                    DockPanel.Dock="Right"
                    Content="搜索用法"
                    MinWidth="78"
                    Click="SearchHelpButton_Click"/>
            <StackPanel>
                <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="记录、Win+V 与数据位置" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="104"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="82"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="CapturePausedBox" Content="暂停记录" Margin="0,0,20,0"/>
                    <CheckBox x:Name="StartWithWindowsBox" Content="开机启动" Margin="0,0,20,0"/>
                    <CheckBox x:Name="CloseAfterCopyBox"
                              Content="复制后隐藏窗口"
                              ToolTip="开启后双击或右键复制记录时，只隐藏窗口，后台继续记录。"
                              Margin="20,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="备用快捷键" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="HotkeyBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Margin="0,0,0,8"
                         ToolTip="Win+V 是主快捷键，会替代 Windows 原生剪贴板历史；这里是额外备用快捷键。"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="容量上限" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="MaxStorageBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="数据位置" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="DataPathBox" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,0,6,8"/>
                <Button Grid.Row="3" Grid.Column="2" Content="更改" Click="ChangeDataPathButton_Click" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="忽略进程" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Top" Margin="0,4,0,0"/>
                <TextBox x:Name="IgnoredProcessesBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Click="CancelButton_Click"/>
            <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
