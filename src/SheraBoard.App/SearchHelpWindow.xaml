<Window x:Class="SheraBoard.App.SearchHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="搜索用法" Height="620" Width="560" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource PageBackground}">
    <Window.Resources>
        <Style x:Key="HelpCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="CodePillStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3FAFA"/>
            <Setter Property="BorderBrush" Value="#CDE7E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,7,7"/>
        </Style>
        <Style x:Key="CodeTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Border Width="36" Height="36" Background="{StaticResource AccentSoftBrush}" CornerRadius="10" DockPanel.Dock="Left" Margin="0,0,10,0">
                <Path Width="17"
                      Height="17"
                      Stretch="Uniform"
                      Stroke="{StaticResource AccentBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Data="M10.8,10.8 L15,15 M6.8,12.2 A5.4,5.4 0,1 1 6.8,1.4 A5.4,5.4 0,0 1 6.8,12.2"/>
            </Border>
            <StackPanel>
                <TextBlock Text="SheraBoard 搜索用法" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="把关键词、来源应用、类型和特征组合起来，越用越快。" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource HelpCardStyle}">
                    <StackPanel>
                        <TextBlock Text="基础搜索" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="直接输入关键词即可；需要完整短语时用英文双引号包起来。" Style="{StaticResource SectionHintStyle}"/>
                        <WrapPanel>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="config" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="毕业论文" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="&quot;hello world&quot;" Style="{StaticResource CodeTextStyle}"/></Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource HelpCardStyle}">
                    <StackPanel>
                        <TextBlock Text="按来源应用" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="适合只看某个软件里复制过的内容；应用筛选弹层也会自动帮你生成这个条件。" Style="{StaticResource SectionHintStyle}"/>
                        <WrapPanel>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="app:vscode" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="app:chrome" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="app:WINWORD" Style="{StaticResource CodeTextStyle}"/></Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource HelpCardStyle}">
                    <StackPanel>
                        <TextBlock Text="按类型" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="类型条件可以和普通关键词一起用。双击记录默认按 SheraBoard 认为最完整的格式复制。" Style="{StaticResource SectionHintStyle}"/>
                        <WrapPanel>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="type:text" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="type:rich" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="type:image" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="type:file" Style="{StaticResource CodeTextStyle}"/></Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource HelpCardStyle}">
                    <StackPanel>
                        <TextBlock Text="按内容特征" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="链接和代码是从内容里识别出来的快速标签，适合从大量记录里缩小范围。" Style="{StaticResource SectionHintStyle}"/>
                        <WrapPanel>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="has:url" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="has:code" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}"><TextBlock Text="is:pinned" Style="{StaticResource CodeTextStyle}"/></Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource HelpCardStyle}">
                    <StackPanel>
                        <TextBlock Text="组合示例" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="多个条件可以同时写，最后再跟普通关键词。" Style="{StaticResource SectionHintStyle}"/>
                        <StackPanel>
                            <Border Style="{StaticResource CodePillStyle}" HorizontalAlignment="Left"><TextBlock Text="app:vscode has:code class" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}" HorizontalAlignment="Left"><TextBlock Text="app:chrome has:url github" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}" HorizontalAlignment="Left"><TextBlock Text="type:image logo" Style="{StaticResource CodeTextStyle}"/></Border>
                            <Border Style="{StaticResource CodePillStyle}" HorizontalAlignment="Left"><TextBlock Text="is:pinned note" Style="{StaticResource CodeTextStyle}"/></Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="关闭" Style="{StaticResource PrimaryButtonStyle}" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
