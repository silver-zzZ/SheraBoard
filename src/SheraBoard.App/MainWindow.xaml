<Window x:Class="SheraBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SheraBoard" Height="764" Width="540" ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource PageBackground}">
    <Window.Resources>
        <Style x:Key="SourceAppPopupScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="6" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#CBD8D8" CornerRadius="3" Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <Image x:Name="HeaderAppIcon"
                       Source="Assets/AppIcon.png"
                       Width="22"
                       Height="22"
                       Margin="0,0,8,0"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="SheraBoard" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="HotkeyHintText" Text="Win+V" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="10,3,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button Content="设置" Click="SettingsButton_Click"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FBFEFE"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Height="42">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Width="16"
                              Height="16"
                              Grid.Column="0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stroke="{StaticResource MutedTextBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Data="M10.8,10.8 L15,15 M6.8,12.2 A5.4,5.4 0,1 1 6.8,1.4 A5.4,5.4 0,0 1 6.8,12.2"/>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 ToolTip="支持 app:vscode、type:image、has:url、has:code、is:pinned"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="SearchPlaceholder"
                                   Grid.Column="1"
                                   Text="搜索内容、来源应用、链接、代码..."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   Margin="0,0,12,1"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <WrapPanel Grid.Row="1" Margin="2,9,0,0">
                    <RadioButton x:Name="DateAllFilter" Content="全部" Tag="All" GroupName="DateFilter" Checked="DateQuickFilter_Changed"/>
                    <RadioButton Content="今天" Tag="Today" GroupName="DateFilter" IsChecked="True" Checked="DateQuickFilter_Changed"/>
                    <RadioButton Content="昨天" Tag="Yesterday" GroupName="DateFilter" Checked="DateQuickFilter_Changed"/>
                    <RadioButton Content="近7天" Tag="Last7Days" GroupName="DateFilter" Checked="DateQuickFilter_Changed"/>
                    <Button x:Name="DatePickerButton" MinWidth="92" Content="选择日期" Click="DatePickerButton_Click"/>
                </WrapPanel>

                <DockPanel Grid.Row="2" Margin="2,7,0,0" LastChildFill="True">
                    <Button x:Name="SourceAppFilterButton"
                            DockPanel.Dock="Right"
                            MinWidth="106"
                            Height="27"
                            Padding="9,0"
                            Margin="7,0,0,0"
                            Click="SourceAppFilterButton_Click"
                            ToolTip="按来源应用筛选，也可以在搜索框输入 app:chrome">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="SourceAppFilterText" Text="应用：全部" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="96"/>
                            <Path Width="8"
                                  Height="5"
                                  Margin="6,1,0,0"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource MutedTextBrush}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M0,0 L4,4 L8,0"/>
                        </StackPanel>
                    </Button>
                    <WrapPanel x:Name="KindFiltersPanel">
                        <RadioButton Content="全部" Tag="All" GroupName="KindFilter" IsChecked="True" Checked="Filter_Changed"/>
                        <RadioButton Content="文字" Tag="Kind:Text" GroupName="KindFilter" Checked="Filter_Changed"/>
                        <RadioButton Content="富文本" Tag="Kind:RichText" GroupName="KindFilter" Checked="Filter_Changed"/>
                        <RadioButton Content="图片" Tag="Kind:Image" GroupName="KindFilter" Checked="Filter_Changed"/>
                        <RadioButton Content="文件" Tag="Kind:FileList" GroupName="KindFilter" Checked="Filter_Changed"/>
                        <RadioButton Content="链接" Tag="Feature:Url" GroupName="KindFilter" Checked="Filter_Changed"/>
                        <RadioButton Content="代码" Tag="Feature:Code" GroupName="KindFilter" Checked="Filter_Changed"/>
                    </WrapPanel>
                </DockPanel>

                <Popup x:Name="DateCalendarPopup"
                       Grid.Row="1"
                       PlacementTarget="{Binding ElementName=DatePickerButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{StaticResource PanelBackground}"
                            BorderBrush="#AAB7B8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="8" Opacity="0.16"/>
                        </Border.Effect>
                        <Calendar x:Name="DateCalendar"
                                  SelectedDatesChanged="DateCalendar_SelectedDatesChanged">
                            <Calendar.LayoutTransform>
                                <ScaleTransform ScaleX="1.18" ScaleY="1.18"/>
                            </Calendar.LayoutTransform>
                        </Calendar>
                    </Border>
                </Popup>

                <Popup x:Name="SourceAppPopup"
                       Grid.Row="2"
                       PlacementTarget="{Binding ElementName=SourceAppFilterButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{StaticResource PanelBackground}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="8"
                            Width="246"
                            Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="7" Opacity="0.13"/>
                        </Border.Effect>
                        <StackPanel>
                            <DockPanel Margin="2,0,2,7">
                                <TextBlock Text="来源应用" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="最近" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SourceAppPopupScrollBarStyle}"/>
                                </ScrollViewer.Resources>
                                <StackPanel x:Name="SourceAppPopupList"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="7" Padding="0">
            <Grid>
                <ListView x:Name="ItemsList" SelectionChanged="ItemsList_SelectionChanged"
                          MouseDoubleClick="ItemsList_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.ScrollChanged="ItemsList_ScrollChanged"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelBackground}" Padding="9,7,7,5">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="36"
                                  Tag="{Binding}"
                                  MouseEnter="ItemRow_MouseEnter"
                                  MouseLeave="ItemRow_MouseLeave"
                                  PreviewMouseRightButtonDown="ItemRow_PreviewMouseRightButtonDown">
                                <Grid.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="复制原格式" Visibility="{Binding CopyOriginalVisibility}" Click="RowCopyOriginalMenu_Click"/>
                                        <MenuItem Header="复制纯文本 / 路径" Visibility="{Binding CopyPlainTextVisibility}" Click="RowCopyPlainTextMenu_Click"/>
                                        <MenuItem Header="复制图片" Visibility="{Binding CopyImageVisibility}" Click="RowCopyImageMenu_Click"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="56"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{Binding KindBackground}"
                                        BorderBrush="{Binding KindBorder}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding KindText}" Foreground="{Binding KindForeground}" FontWeight="SemiBold" FontSize="11"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="6,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PreviewText}" FontSize="12.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SourceApp}" Foreground="{StaticResource MutedTextBrush}" FontSize="10.5" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding TimeText}" Foreground="{StaticResource MutedTextBrush}" FontSize="10.5" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            ToolTip="固定"
                                            Tag="{Binding}"
                                            Click="RowPinButton_Click">
                                        <Path Width="16" Height="16"
                                              Stretch="Uniform"
                                              Fill="Transparent"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M15,4.5 L11,8.5 L7,10 L5.5,11.5 L12.5,18.5 L14,17 L15.5,13 L19.5,9 M9,15 L4.5,19.5 M14.5,4 L20,9.5">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Stroke" Value="{StaticResource MutedTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Record.Pinned}" Value="True">
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            ToolTip="删除"
                                            Tag="{Binding}"
                                            Click="RowDeleteButton_Click">
                                        <Path Width="16" Height="16"
                                              Stretch="Uniform"
                                              Fill="Transparent"
                                              Stroke="{StaticResource MutedTextBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4,7 L20,7 M10,11 L10,17 M14,11 L14,17 M5,7 L6,19 A2,2 0,0 0 8,21 L16,21 A2,2 0,0 0 18,19 L19,7 M9,7 L9,4 A1,1 0,0 1 10,3 L14,3 A1,1 0,0 1 15,4 L15,7"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border x:Name="EmptyStatePanel" Background="{StaticResource PanelMutedBackground}" Visibility="Collapsed" CornerRadius="7">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="280">
                        <Image Source="Assets/AppIcon.png" Width="36" Height="36" Opacity="0.86"/>
                        <TextBlock x:Name="EmptyStateTitleText" Text="还没有剪贴板记录" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,9,0,0"/>
                        <TextBlock x:Name="EmptyStateDescriptionText"
                                   Text="复制文字、图片或文件后会自动出现在这里。"
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ToastPanel"
                Grid.RowSpan="3"
                Panel.ZIndex="50"
                Visibility="Collapsed"
                Opacity="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,42,0,0"
                CornerRadius="14"
                Padding="12,7"
                Background="#F8FBFF"
                BorderBrush="#C7DBFF"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="7" Opacity="0.16"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="18" Height="18" CornerRadius="9" Background="{StaticResource AccentBrush}" Margin="0,0,7,0">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Data="M2,5 L4.3,7.4 L8.5,2.5"/>
                </Border>
                <TextBlock x:Name="ToastText" Foreground="{StaticResource TextBrush}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Popup x:Name="HoverPreviewPopup"
               Placement="Right"
               HorizontalOffset="10"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade">
            <Border Background="{StaticResource PanelBackground}"
                    BorderBrush="#AAB7B8"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="11"
                    MaxWidth="620"
                    MaxHeight="500"
                    MouseEnter="HoverPreviewPopup_MouseEnter"
                    MouseLeave="HoverPreviewPopup_MouseLeave">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="10" Opacity="0.20"/>
                </Border.Effect>
                <Grid>
                    <ScrollViewer x:Name="HoverPreviewTextScroll" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="HoverPreviewTextBlock" TextWrapping="Wrap" FontSize="12.5" LineHeight="19"/>
                    </ScrollViewer>
                    <RichTextBox x:Name="HoverPreviewRichBox"
                                 Visibility="Collapsed"
                                 Width="560"
                                 MaxHeight="420"
                                 Padding="0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 IsReadOnly="True"
                                 IsDocumentEnabled="False"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"/>
                    <Border x:Name="HoverPreviewImagePanel"
                            Visibility="Collapsed"
                            Background="#F1F7FF"
                            CornerRadius="7"
                            MaxWidth="590"
                            MaxHeight="440"
                            Cursor="Hand"
                            ToolTip="点击放大图片，滚轮缩放"
                            MouseLeftButtonUp="HoverPreviewImagePanel_MouseLeftButtonUp">
                        <Image x:Name="HoverPreviewImage" Stretch="Uniform" Margin="8" MaxWidth="574" MaxHeight="424"/>
                    </Border>
                    <ListBox x:Name="HoverPreviewFilesList" Visibility="Collapsed" MaxHeight="420" FontSize="12.5"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>

